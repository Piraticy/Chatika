{
  "expo": {
    "name": "Chatika",
    "slug": "chatika",
    "version": "0.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0A1221"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chatika.app"
    },
    "android": {
      "package": "com.chatika.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A1221",
        "foregroundImage": "./assets/icon.png"
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
